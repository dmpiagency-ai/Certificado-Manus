rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === USERS ===
    // Cada utilizador só pode ler e escrever o seu próprio documento
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Criação: utilizador autenticado cria o seu próprio perfil
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['email', 'whatsapp', 'credits', 'createdAt', 'updatedAt'])
                    && request.resource.data.credits is number
                    && request.resource.data.credits >= 0
                    && request.resource.data.whatsapp is string;

      // Update: só pode alterar créditos e updatedAt
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['credits', 'updatedAt'])
                    && request.resource.data.credits is number
                    && request.resource.data.credits >= 0;
    }

    // === TEMPLATES ===
    // Cada utilizador só acede aos seus próprios templates
    match /templates/{templateId} {
      allow read, write: if request.auth != null
                         && (
                           // Leitura/escrita apenas se o owner for o utilizador autenticado
                           (resource == null && request.resource.data.ownerId == request.auth.uid)
                           || (resource != null && resource.data.ownerId == request.auth.uid)
                         );
    }

    // Negar tudo o resto por defeito
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
